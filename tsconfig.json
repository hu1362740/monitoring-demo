{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@monitoring/sdk": ["packages/sdk/src/index.ts"],
      "@monitoring/server": ["packages/server/src/index.ts"]
    }
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}
